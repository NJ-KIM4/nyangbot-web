# Discord OAuth2 (Discord Developer Portal에서 발급)
DISCORD_CLIENT_ID=your_bot_client_id
DISCORD_CLIENT_SECRET=your_client_secret

# JWT 시크릿 (랜덤 문자열, 프로덕션에서 반드시 변경)
JWT_SECRET=your-random-jwt-secret-key

# 봇 API URL (Google Cloud VM에서 실행 중인 Express API)
NEXT_PUBLIC_BOT_API_URL=http://your-vm-ip:3001/api

# 웹 사이트 베이스 URL (OAuth 리다이렉트용)
NEXT_PUBLIC_BASE_URL=http://localhost:3000

# 관리자 Discord ID 목록 (쉼표 구분)
NEXT_PUBLIC_ADMIN_IDS=your_discord_id
